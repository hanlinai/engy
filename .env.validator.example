# engy sn53 light validator — configuration
# Copy to .env.validator and fill in your values:  cp .env.validator.example .env.validator

# =============================================================================
# Required
# =============================================================================
# engy-provider API base URL (the coordination layer serving signed epoch results).
ENGY_SN53_API=https://provider.engy.ai

# The master validator hotkey, pinned locally. This is the ONLY root of trust:
# the light validator verifies every weight vector against this key and never
# trusts the payload's own signed_hotkey field. Get the current value from
# GET {ENGY_SN53_API}/api/subnet/v1/epoch/params.
ENGY_SN53_MASTER_HOTKEY=

# =============================================================================
# On-chain wallet (for set_weights) — mounted read-only into the container
# =============================================================================
ENGY_SN53_WALLET=default
ENGY_SN53_WALLET_HOTKEY=default

# =============================================================================
# Optional (defaults shown) — usually leave as-is
# =============================================================================
ENGY_SN53_NETUID=53
ENGY_SN53_NETWORK=finney
# Poll interval in seconds. This drives two things: picking up a new epoch,
# and the resubmit cadence that keeps the validator inside activity_cutoff.
# It must stay well below the resubmit interval (100 blocks ≈ 20 min) or
# scheduling precision is lost to poll granularity.
ENGY_SN53_POLL_S=300
# Where submission state is persisted (applied epoch, last submit block and
# the vector to fall back on). In Docker this is a named volume so a restart
# resumes the resubmit schedule. Do not change unless you also change the
# compose volume mount.
ENGY_SN53_STATE_FILE=/var/lib/engy-sn53/state.json
# Liveness marker, stamped after every poll cycle (not just applied epochs).
# The container HEALTHCHECK and the in-process watchdog both read it; a loop
# that stops ticking for 3 poll intervals exits so Docker restarts it.
ENGY_SN53_HEARTBEAT_FILE=/var/lib/engy-sn53/heartbeat.json
# Blocks between resubmissions of the same epoch's vector. The chain treats a
# validator whose last_update exceeds activity_cutoff (~5000 blocks) as
# inactive and drops its weights from consensus, so the vector is resubmitted
# for the whole epoch rather than once. Must be >= the subnet's
# weights_rate_limit or every submission is refused.
# ENGY_SN53_RESUBMIT_BLOCKS=100
# Protocol genesis (pinned constant; override only on a testnet).
# ENGY_SN53_GENESIS_TS=1784505600
